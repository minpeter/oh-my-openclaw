{
  name: 'apex',
  description: 'All-in-one power assistant preset with secure prompt-guard defaults',
  version: '1.0.0',
  author: 'oh-my-openclaw',
  tags: ['all-in-one', 'security', 'developer', 'assistant', 'tmux', 'prompt-guard', 'agent-browser'],
  builtin: true,
  config: {
    identity: {
      name: 'Apex',
      theme: 'all-in-one power assistant',
      emoji: '⚡',
    },
    agents: {
      defaults: {
        model: {
          primary: 'anthropic/claude-opus-4-6',
        },
        contextTokens: 700000,
        models: {
          'anthropic/claude-opus-4-6': {
            params: {
              context1m: true,
              speed: 'fast',
            },
          },
        },
      },
    },
    tools: {
      allow: [
        'exec',
        'process',
        'read',
        'write',
        'edit',
        'apply_patch',
        'browser',
        'web_search',
        'web_fetch',
        'cron',
        'image',
        'memory_search',
        'memory_get',
        'message',
        'canvas',
      ],
    },
    channels: {
      discord: {
        allowBots: true,
      },
    },
    // Model routing: select model based on task type.
    // Coding/development tasks get the strongest model;
    // casual conversation and simple queries use a faster, lighter model.
    routing: {
      defaultModel: 'anthropic/claude-sonnet-4-6',
      rules: [
        {
          name: 'coding',
          description: 'Code generation, debugging, refactoring, and development tasks',
          triggers: [
            'tmux-opencode',
            'code',
            'development',
            'debugging',
            'refactoring',
            'architecture',
            'code-review',
          ],
          model: 'anthropic/claude-opus-4-6',
        },
      ],
    },
  },
  workspaceFiles: ['AGENTS.md', 'SOUL.md', 'USER.md', 'IDENTITY.md'],
  skills: ['prompt-guard', 'tmux-opencode', 'agent-browser'],
}
