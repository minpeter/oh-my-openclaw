{
  "name": "oh-my-openclaw",
  "version": "1.1.3",
  "type": "module",
  "description": "CLI tool for managing OpenClaw agent presets",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minpeter/oh-my-openclaw.git"
  },
  "homepage": "https://github.com/minpeter/oh-my-openclaw#readme",
  "bugs": {
    "url": "https://github.com/minpeter/oh-my-openclaw/issues"
  },
  "keywords": [
    "openclaw",
    "cli",
    "preset",
    "agent",
    "configuration"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "apex": "src/cli.ts"
  },
  "files": [
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check:biome": "biome check .",
    "check:types": "tsc --noEmit",
    "check": "bun run check:biome && bun run check:types",
    "build": "bun build src/cli.ts --outdir dist --target bun --format esm",
    "build:compile": "bun build src/cli.ts --compile --bytecode --outfile dist/apex",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3",
    "ultracite": "7.2.4"
  }
}
